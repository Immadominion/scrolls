# Root-level safety net — subdirectory .gitignores also apply

# Never commit secrets
.env
.env.local
.env.production.local
.env.*.local
.dev.vars

# Cloudflare Wrangler state (local cache, not source)
**/.wrangler/

# Node / package manager
node_modules/
.pnpm-debug.log*

# OS / editor
.DS_Store
*.pem
.idea/
.vscode/*.log
