{
    "name": "@scrolls/mcp",
    "version": "0.1.0",
    "description": "Model Context Protocol server for Scrolls. Lets Claude (and any MCP-aware agent) create and read Walrus-native forms.",
    "license": "MIT",
    "type": "module",
    "bin": {
        "scrolls-mcp": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --clean --target node20 --no-splitting",
        "dev": "tsup src/index.ts --format esm --watch --target node20 --no-splitting",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.4",
        "@scrolls/sdk": "file:../sdk",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsup": "^8.3.5",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "mcp",
        "scrolls",
        "walrus",
        "sui",
        "anthropic",
        "claude"
    ]
}