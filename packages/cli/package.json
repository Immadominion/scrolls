{
    "name": "@scrolls/cli",
    "version": "0.1.0",
    "description": "Scrolls CLI — create Walrus-native forms from your terminal.",
    "license": "MIT",
    "type": "module",
    "bin": {
        "scrolls": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --clean --target node20 --no-splitting",
        "dev": "tsup src/index.ts --format esm --watch --target node20 --no-splitting",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@scrolls/sdk": "file:../sdk",
        "commander": "^12.1.0",
        "picocolors": "^1.1.1",
        "prompts": "^2.4.2"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/prompts": "^2.4.9",
        "tsup": "^8.3.5",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "scrolls",
        "walrus",
        "sui",
        "forms",
        "cli"
    ]
}