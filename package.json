{
    "name": "scrolls-workspace",
    "private": true,
    "version": "0.0.0",
    "description": "Top-level workspace for the @scrolls/* npm packages (SDK, CLI, MCP).",
    "scripts": {
        "build": "pnpm -r --filter ./packages/* build",
        "build:sdk": "pnpm --filter @scrolls/sdk build",
        "build:cli": "pnpm --filter @scrolls/cli build",
        "build:mcp": "pnpm --filter @scrolls/mcp build",
        "typecheck": "pnpm -r --filter ./packages/* typecheck",
        "scrolls": "node packages/cli/dist/index.js",
        "mcp": "node packages/mcp/dist/index.js"
    },
    "engines": {
        "node": ">=20"
    },
    "packageManager": "pnpm@10.33.1",
    "dependencies": {
        "@mdx-js/react": "^3.1.1",
        "next-mdx-remote": "^6.0.0",
        "react-markdown": "^10.1.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-raw": "^7.0.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1"
    }
}
