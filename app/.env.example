# Scrolls App — environment variables
#
# Copy this file to `.env.local` and fill in real values for local dev.
# `.env.local` is gitignored. NEVER commit secrets.
#
# IMPORTANT: every NEXT_PUBLIC_* variable is bundled into the browser JS.
# Do NOT put any private API key in this file. Private API keys (Anthropic,
# OpenAI, Groq) belong only inside the ai-proxy Cloudflare Worker as
# `wrangler secret`s.


# ─── Walrus Storage ─────────────────────────────────────────────
# Development: use testnet endpoints (free storage, fast)
# Submission (Phase 7): flip to mainnet endpoints
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Mainnet endpoints (for Phase 7 submission):
# NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space
# NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus.space
# How many epochs to store blobs (1 epoch ≈ 1 day on testnet, varies on mainnet)
NEXT_PUBLIC_WALRUS_EPOCHS=5


# ─── Sui Network ────────────────────────────────────────────────
# Development: testnet (free faucet SUI, stable network)
# Submission (Phase 7): flip to mainnet
# Options: devnet | testnet | mainnet
NEXT_PUBLIC_SUI_NETWORK=mainnet


# ─── AI Proxy (Cloudflare Worker) ───────────────────────────────
# Worker that forwards requests to Anthropic Claude Haiku and OpenAI Whisper.
# Local dev: pnpm --dir ../ai-proxy dev  →  http://localhost:8787
# See ../ai-proxy/README.md for setup.
NEXT_PUBLIC_AI_PROXY_URL=http://localhost:8787
# Legacy alias used by AI builder voice + chat code (same Worker URL).
NEXT_PUBLIC_CLAUDE_PROXY_URL=http://localhost:8787

# ─── Short links ────────────────────────────────────────────────
# Public origin that fronts the Worker's `/s/<code>` redirect.
# In production this is your apex domain (e.g. https://scrolls.fun)
# routed to the same Worker via a Cloudflare Route.
# In dev it's the worker itself.
NEXT_PUBLIC_SHORT_LINK_BASE=http://localhost:8787
