# ─────────────────────────────────────────────────────────────────
# Scrolls — production environment template
#
# Default profile: HYBRID
#   • Walrus    → mainnet (permanent, real WAL storage cost)
#   • Sui       → testnet (Move package + Seal already wired here)
#
# This is the recommended profile for the bounty submission: form
# data lives on real Walrus, but registry/Seal ops are free. Switch
# to full Sui mainnet only after publishing the Move package on
# mainnet and wiring SEAL_KEY_SERVERS.mainnet in src/lib/contracts.ts.
#
# Copy to `.env.production.local` (NEVER commit it) before running
# `pnpm build`, or paste the values into your Vercel / Walrus Sites
# build environment.
#
# Every NEXT_PUBLIC_* value below is shipped to the browser. Do not
# put server secrets here — Anthropic / OpenAI keys live ONLY as
# `wrangler secret`s on the Cloudflare Worker (`ai-proxy/`).
# ─────────────────────────────────────────────────────────────────

# Sui — mainnet (Move package 0xbd376f7e… is published on mainnet).
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Walrus mainnet aggregator + publisher (Mysten-operated reference nodes).
# You can substitute any operator from the published Walrus operator list.
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus.space

# How many epochs a published blob should be retained for. Increase for
# longer-lived forms — be aware this affects Walrus storage cost.
NEXT_PUBLIC_WALRUS_EPOCHS=10

# Cloudflare Worker proxy URL for Claude Haiku + Whisper.
# Deploy ai-proxy/ to your own Workers account first and paste the URL here.
NEXT_PUBLIC_AI_PROXY_URL=https://scrolls-ai.<your-subdomain>.workers.dev
# Legacy alias (still read by older code paths).
NEXT_PUBLIC_CLAUDE_PROXY_URL=https://scrolls-ai.<your-subdomain>.workers.dev

# Public origin that fronts the Worker's `/s/<code>` short-link redirect.
# Defaults to the Worker URL itself. If you've added a Cloudflare Route
# `<your-domain>/s/*` -> the Worker, set this to your apex domain.
NEXT_PUBLIC_SHORT_LINK_BASE=https://scrolls-ai.<your-subdomain>.workers.dev

# Enoki (zkLogin via Sign-in-with-Google). Leave blank to disable Google
# sign-in — extension wallets will still work.
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
